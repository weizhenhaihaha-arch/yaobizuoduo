{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yaobizuoduo.invalid/schemas/project-status.v1.json",
  "title": "yaobizuoduo canonical project status",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "project", "current_gate", "active_tasks", "evidence", "review", "ci", "capability", "blockers", "next_authorization", "governed_documents"],
  "properties": {
    "schema_version": {"const": "project-status.v1"},
    "project": {"const": "yaobizuoduo"},
    "current_gate": {"enum": ["G0", "G1", "G2", "G3", "G4", "G5", "G6", "G7", "G8", "G9"]},
    "active_tasks": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": {"$ref": "#/$defs/task"}
    },
    "evidence": {"$ref": "#/$defs/evidence"},
    "review": {"$ref": "#/$defs/review"},
    "ci": {"$ref": "#/$defs/ci"},
    "capability": {"$ref": "#/$defs/capability"},
    "blockers": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "next_authorization": {"$ref": "#/$defs/nextAuthorization"},
    "governed_documents": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "pattern": "^[A-Za-z0-9_./-]+$"}
    }
  },
  "$defs": {
    "sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "nullableSha": {"type": ["string", "null"], "pattern": "^[0-9a-f]{40}$"},
    "state": {"enum": ["planned", "authorized", "in_progress", "awaiting_review", "returned", "blocked", "accepted_pending_merge", "merged_verified", "closed"]},
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["task_id", "risk", "state", "transition", "candidate_generation"],
      "properties": {
        "task_id": {"type": "string", "pattern": "^G[0-9]-T[0-9]{2}$"},
        "risk": {"enum": ["D0", "D1", "D2"]},
        "state": {"$ref": "#/$defs/state"},
        "transition": {
          "type": "object",
          "additionalProperties": false,
          "required": ["from", "to"],
          "properties": {"from": {"$ref": "#/$defs/state"}, "to": {"$ref": "#/$defs/state"}}
        },
        "candidate_generation": {"type": "integer", "minimum": 1}
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["baseline_sha", "candidate_sha", "closure_sha", "implementation_merge_sha", "finalization_sha"],
      "properties": {
        "baseline_sha": {"$ref": "#/$defs/sha"},
        "candidate_sha": {"$ref": "#/$defs/nullableSha"},
        "closure_sha": {"$ref": "#/$defs/nullableSha"},
        "implementation_merge_sha": {"$ref": "#/$defs/nullableSha"},
        "finalization_sha": {"$ref": "#/$defs/nullableSha"}
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code_security", "architecture", "reviewed_candidate_sha"],
      "properties": {
        "code_security": {"enum": ["pending", "approve", "request_changes", "blocked"]},
        "architecture": {"enum": ["pending", "clear", "block"]},
        "reviewed_candidate_sha": {"$ref": "#/$defs/nullableSha"}
      }
    },
    "ci": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "head_sha", "run_id", "url"],
      "properties": {
        "status": {"enum": ["not_established", "not_run", "pending", "success", "failure"]},
        "head_sha": {"$ref": "#/$defs/nullableSha"},
        "run_id": {"type": ["string", "null"], "pattern": "^[1-9][0-9]*$"},
        "url": {"type": ["string", "null"], "pattern": "^https://github\\.com/[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+/actions/runs/[1-9][0-9]*$"}
      }
    },
    "capability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maturity", "legacy_maximum"],
      "properties": {
        "maturity": {"enum": ["OFFLINE_EVIDENCE_ACCEPTED", "INTEGRATION_ACCEPTED", "PAPER_VALIDATED", "RELEASE_READY"]},
        "legacy_maximum": {"const": "OFFLINE_EVIDENCE_ACCEPTED"}
      }
    },
    "nextAuthorization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gate", "task_id", "state"],
      "properties": {
        "gate": {"enum": ["G0", "G1", "G2", "G3", "G4", "G5", "G6", "G7", "G8", "G9"]},
        "task_id": {"type": "string", "pattern": "^G[0-9]-T[0-9]{2}$"},
        "state": {"const": "not_authorized"}
      }
    }
  }
}
